{
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "autoolinda-5199e",
          "appId": "1:992114921273:android:60d820df26a029550de2e8",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "autoolinda-5199e",
          "configurations": {
            "android": "1:992114921273:android:60d820df26a029550de2e8",
            "ios": "1:992114921273:ios:2a90914ba4b1dab20de2e8",
            "web": "1:992114921273:web:0b81f9a88b2e14610de2e8"
          }
        }
      }
    }
  },
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint"
      ]
    }
  ],
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "storage": {
    "rules": "storage.rules"
  }
}
