rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Booking photos - allow authenticated users to read/write
    match /bookings/{bookingId}/{folder}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024  // Max 10MB
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Profile photos - user can only write their own photo
    match /profile_photos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null 
                   && fileName == request.auth.uid + '.jpg'
                   && request.resource.size < 5 * 1024 * 1024  // Max 5MB
                   && request.resource.contentType.matches('image/.*');
    }
    
    // User profile photos (legacy path)
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
