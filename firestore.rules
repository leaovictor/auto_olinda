rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // HELPER FUNCTIONS
    // -----------------------------------------------------------------

    // 1. Basic Auth Check
    function isAuthenticated() {
      return request.auth != null;
    }

    // 2. Tenant Isolation Check (Via Claims - Zero Cost)
    function isTenantMember(tenantId) {
      return isAuthenticated() && 
             request.auth.token.tenantId == tenantId;
    }

    // 3. Tenant Blocked Status Check (Database Lookup - 1 Read Cost)
    // Ensures immediate blocking of access if tenant is suspended/blocked.
    function isTenantActive(tenantId) {
      let tenantStatus = get(/databases/$(database)/documents/tenants/$(tenantId)).data.status;
      return tenantStatus != 'blocked';
    }

    // 4. Role Checks (Via Claims)
    function isAdmin() {
      return request.auth.token.role in ['admin', 'owner'];
    }
    
    function isStaff() {
      // Staff includes admins/owners implicitly for operational access, 
      // or explicitly check 'staff'/'member'
      return request.auth.token.role in ['staff', 'member', 'admin', 'owner'];
    }

    // Combined Access Check
    function canAccessTenant(tenantId) {
      return isTenantMember(tenantId) && isTenantActive(tenantId);
    }

    // -----------------------------------------------------------------
    // RULES
    // -----------------------------------------------------------------

    // [Users] - User can only read/write their own profile
    // Note: Users are at root level in your current structure, but linked to tenants.
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }

    // [Invites] - Security for Invite System
    match /invites/{inviteId} {
        // Only allow reading invites by email (for acceptance check) 
        // or by Admins of the creating tenant.
        // Simplified for this task to focus on Multi-tenant structure.
        allow read: if isAuthenticated(); 
    }

    // [Tenants] - Root of Logic
    match /tenants/{tenantId} {
      
      // Tenant Document itself
      // Read: All active members can read basic tenant info
      // Write: Only Owner/Admin can update tenant settings
      allow read: if canAccessTenant(tenantId);
      allow write: if canAccessTenant(tenantId) && isAdmin();

      // [Subcollections] - Recursive match to cover all nested data
      // This applies to: customers, orders, appointments, etc.
      match /{document=**} {
        allow read: if canAccessTenant(tenantId) && isStaff();
        allow write: if canAccessTenant(tenantId) && isStaff();
      }

      // [Billing] - SENSITIVE AREA (Override recursive match)
      // Specific match for billing subcollections to restrict access
      match /billing/{document=**} {
        allow read: if canAccessTenant(tenantId) && isAdmin();
        allow write: if canAccessTenant(tenantId) && isAdmin();
      }
      
      match /billing_events/{document=**} {
        allow read: if canAccessTenant(tenantId) && isAdmin();
        allow write: if false; // System only
      }
    }
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
