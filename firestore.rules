rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================================
    // HELPER FUNCTIONS
    // =========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // Read role and tenantId from Custom Claims (set by setUserRole CF).
    // This avoids an extra Firestore read per rule evaluation.
    function getClaim(key) {
      return request.auth.token[key];
    }

    function userRole() {
      return getClaim('role');
    }

    function userTenantId() {
      return getClaim('tenantId');
    }

    function isSuperAdmin() {
      return isAuthenticated() && userRole() == 'superAdmin';
    }

    // tenantOwner OR legacy 'admin' role
    function isTenantAdmin() {
      return isAuthenticated() &&
             (userRole() == 'tenantOwner' || userRole() == 'admin');
    }

    function isStaff() {
      return isAuthenticated() && userRole() == 'staff';
    }

    function isStaffOrAdmin() {
      return isTenantAdmin() || isStaff();
    }

    function hasAdminAccess() {
      return isSuperAdmin() || isStaffOrAdmin();
    }

    // True when the caller belongs to this tenant
    function belongsToTenant(tenantId) {
      return isAuthenticated() && userTenantId() == tenantId;
    }

    // Tenant-admin/staff of THIS tenant
    function isTenantStaffOrAdmin(tenantId) {
      return belongsToTenant(tenantId) && isStaffOrAdmin();
    }

    function isTenantAdminOf(tenantId) {
      return belongsToTenant(tenantId) && isTenantAdmin();
    }

    // =========================================================================
    // TENANTS (root — superAdmin only for write; owning tenant for read)
    // =========================================================================

    match /tenants/{tenantId} {
      // SuperAdmin: full access to all tenants
      allow read, write: if isSuperAdmin();

      // Tenant members: read their own tenant doc (for branding / settings)
      allow read: if belongsToTenant(tenantId);

      // TenantOwner: update their own branding/settings (not status/plan)
      allow update: if isTenantAdminOf(tenantId) &&
                       !request.resource.data.diff(resource.data)
                          .affectedKeys()
                          .hasAny(['status', 'plan', 'platformFeePercent',
                                   'stripeConnectAccountId', 'stripeConnectOnboarded',
                                   'ownerUid']);

      // ── Tenant subcollections ──────────────────────────────────────────────

      match /appointments/{appointmentId} {
        allow create: if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          request.resource.data.userId == request.auth.uid);
        allow read:   if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid);
        // Staff/admin can update status; customer can only update ratings
        allow update: if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid &&
                          !request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasAny(['status', 'totalPrice', 'serviceIds',
                                      'scheduledTime']));
        allow delete: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /services/{serviceId} {
        allow read:  if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /plans/{planId} {
        allow read:  if belongsToTenant(tenantId) || isSuperAdmin();
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /subscriptions/{subscriptionId} {
        // Only Cloud Functions (Admin SDK) can create — enforced by Stripe webhook
        allow create: if false;
        allow read:   if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid);
        allow update: if isTenantAdminOf(tenantId) || isSuperAdmin();
        allow delete: if false;
      }

      match /vehicles/{vehicleId} {
        allow create: if belongsToTenant(tenantId) &&
                         request.resource.data.userId == request.auth.uid;
        allow read:   if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid);
        allow update: if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid);
        allow delete: if isTenantAdminOf(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid &&
                          resource.data.isSubscriptionVehicle != true);
      }

      match /availability/{dateId} {
        allow read:  if belongsToTenant(tenantId);
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /admin_events/{eventId} {
        allow read, write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /wash_logs/{logId} {
        // Written only by Cloud Functions
        allow write: if false;
        allow read:  if isTenantStaffOrAdmin(tenantId) || isSuperAdmin();
      }

      match /subscription_status_logs/{logId} {
        allow write: if false;
        allow read:  if isTenantStaffOrAdmin(tenantId) || isSuperAdmin();
      }

      match /aggregated_metrics/{metricId} {
        allow write: if false;
        allow read:  if isTenantStaffOrAdmin(tenantId) || isSuperAdmin();
      }

      match /fcm_notification_logs/{logId} {
        allow write: if false;
        allow read:  if isTenantStaffOrAdmin(tenantId) || isSuperAdmin();
      }

      match /settings/{settingId} {
        allow read:  if belongsToTenant(tenantId);
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /admin_settings/{settingId} {
        allow read, write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /leads_clients/{plate} {
        allow read, write: if isTenantStaffOrAdmin(tenantId) || isSuperAdmin();
        allow update: if belongsToTenant(tenantId) &&
                         (resource.data.uid == null || resource.data.uid == '') &&
                         request.resource.data.uid == request.auth.uid;
      }

      match /servicos_ativos/{serviceId} {
        allow read:         if true;
        allow read, write:  if isTenantStaffOrAdmin(tenantId) || isSuperAdmin();
        allow update:       if belongsToTenant(tenantId) &&
                               (resource.data.userId == null ||
                                resource.data.userId == '') &&
                               request.resource.data.userId == request.auth.uid;
      }

      match /config/{configId} {
        allow read:  if belongsToTenant(tenantId) || true; // public for availability calendar
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
        match /blocked_dates/{dateId} {
          allow read:  if belongsToTenant(tenantId);
          allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
        }
      }

      match /independent_services/{serviceId} {
        allow read:  if true;
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /service_availability/{availabilityId} {
        allow read:  if belongsToTenant(tenantId);
        allow write: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }

      match /service_bookings/{bookingId} {
        allow create: if belongsToTenant(tenantId) &&
                         request.resource.data.userId == request.auth.uid;
        allow read:   if belongsToTenant(tenantId);
        allow update: if isTenantStaffOrAdmin(tenantId) ||
                         (belongsToTenant(tenantId) &&
                          resource.data.userId == request.auth.uid &&
                          !request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasAny(['totalPrice', 'serviceId',
                                      'scheduledTime', 'paymentStatus',
                                      'paidAmount']));
        allow delete: if isTenantAdminOf(tenantId) || isSuperAdmin();
      }
    }

    // =========================================================================
    // USERS (global — role+tenantId stored here for Auth bootstrap)
    // =========================================================================

    match /users/{userId} {
      // SuperAdmin: read all
      allow read: if isSuperAdmin();

      // User reads/writes own document; tenant staff reads same-tenant users
      allow read: if request.auth != null && request.auth.uid == userId;
      allow read: if isStaffOrAdmin() && (
                     isSuperAdmin() ||
                     resource.data.tenantId == userTenantId()
                  );

      // Only the user or admin SDK can write
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if (request.auth != null && request.auth.uid == userId) ||
                       isTenantAdminOf(resource.data.tenantId) ||
                       isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /notifications/{notificationId} {
        allow read:   if request.auth != null && request.auth.uid == userId;
        allow write:  if isTenantStaffOrAdmin(userTenantId()) || isSuperAdmin();
        allow update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // =========================================================================
    // NDA ACCEPTANCES (immutable, global — cross-tenant legal record)
    // =========================================================================

    match /nda_acceptances/{id} {
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == request.auth.uid;
      allow read:   if isSuperAdmin() ||
                       isStaffOrAdmin() ||
                       (isAuthenticated() &&
                        resource.data.userId == request.auth.uid);
      allow update, delete: if false;
    }

    // =========================================================================
    // REVIEW TAGS (global reference data)
    // =========================================================================

    match /reviewTags/{tagId} {
      allow read:  if true;
      allow write: if isSuperAdmin();
    }

    // =========================================================================
    // LEGACY ROOT COLLECTIONS
    // These remain readable during the migration window.
    // Once data is fully migrated to /tenants/{id}/* subcollections,
    // remove these rules and the corresponding Firestore indexes.
    // =========================================================================

    match /appointments/{id}    { allow read, write: if false; } // migrated
    match /services/{id}        { allow read, write: if false; } // migrated
    match /plans/{id}           { allow read, write: if false; } // migrated
    match /subscriptions/{id}   { allow read, write: if false; } // migrated
    match /vehicles/{id}        { allow read, write: if false; } // migrated
    match /availability/{id}    { allow read, write: if false; } // migrated
    match /wash_logs/{id}       { allow read, write: if false; } // migrated
    match /admin_events/{id}    { allow read, write: if false; } // migrated
    match /aggregated_metrics/{id} { allow read, write: if false; } // migrated
    match /subscription_status_logs/{id} { allow read, write: if false; } // migrated

    // Legacy: kept open during backfill window; lock down after seed script runs
    match /leads_clients/{id}   { allow read, write: if isStaffOrAdmin(); }
    match /servicos_ativos/{id} { allow read: if true; allow write: if isStaffOrAdmin(); }
    match /bookings/{id}        { allow read, write: if isSuperAdmin(); }
    match /orders/{id}          { allow read, write: if false; }
    match /coupons/{id}         { allow read, write: if false; }
    match /products/{id}        { allow read, write: if false; }
    match /prices/{id}          { allow read, write: if false; }
  }
}
