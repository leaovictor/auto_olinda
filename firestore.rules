rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Fetch user role from the 'users' collection
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data != null ? userDoc.data.role : null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }

    function isStaffOrAdmin() {
      return isAdmin() || isStaff();
    }

    // --- Collection Rules ---

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaffOrAdmin();
      allow write: if isOwner(userId) || isAdmin();

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow write: if isStaffOrAdmin(); // Staff/Admin send notifications
        allow update: if isOwner(userId); // Client marks as read
      }

      // Vehicles subcollection (user's vehicles)
      match /vehicles/{vehicleId} {
        allow read: if isOwner(userId) || isStaffOrAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Vehicles collection
    match /vehicles/{vehicleId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isStaffOrAdmin();
      allow update, delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Appointments collection (Active)
    match /appointments/{appointmentId} {
      // Creation blocked for clients (Must use Cloud Function createBooking)
      allow create: if false; 
      
      // Allow authenticated users to read appointments for availability calculation
      // This is needed for the booking screen to show available time slots
      allow read: if isAuthenticated();
      
      // Update blocked for critical fields if not Admin/Staff
      // Clients can only update non-critical fields (like ratings)
      allow update: if isStaffOrAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'totalPrice', 'serviceIds', 'scheduledTime'])
      );
    }

    // Legacy Bookings
    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Plans collection
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons collection
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Orders collection (product payments)
    match /orders/{orderId} {
      // Staff and Admin can read all orders
      allow read: if isStaffOrAdmin();
      // Clients can read their own orders
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Admin/Staff can list all subscriptions (needed for dashboard metrics)
      // Regular users can only read their own subscription
      allow read: if isStaffOrAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Subscription Status Logs (audit trail for subscription changes)
    match /subscription_status_logs/{logId} {
      allow read: if isStaffOrAdmin();
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // Aggregated Metrics (pre-computed metrics for dashboard)
    match /aggregated_metrics/{metricId} {
      allow read: if isStaffOrAdmin();
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // Wash Logs (records of completed washes for analytics)
    match /wash_logs/{logId} {
      allow read: if isStaffOrAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Only Cloud Functions can write (via Admin SDK)
      allow write: if false;
    }

    // Availability collection
    match /availability/{dateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings collection (Admin settings)
    match /settings/{settingId} {
      allow read: if isStaffOrAdmin();
      allow write: if isAdmin();
    }

    // Config collection (Calendar, etc.)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /blocked_dates/{dateId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Admin Events collection
    match /admin_events/{eventId} {
      allow read, write: if isAdmin();
    }

    // NDA Acceptances (Immutable audit log)
    match /nda_acceptances/{id} {
      // Allow users to create their own acceptance record
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid;
      // Admins can audit all, Users can read their own
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Immutable: No updates or deletions allowed
      allow update, delete: if false;
    }

    // =====================================================
    // Independent Services (Estética: Insufilm, etc.)
    // =====================================================

    // Independent Services collection (Admin manages, clients read)
    match /independent_services/{serviceId} {
      allow read: if true; // Public read for service listing
      allow write: if isAdmin();
    }

    // Service Availability (slots per date/service)
    match /service_availability/{availabilityId} {
      allow read: if isAuthenticated(); // Clients need to read for booking
      allow write: if isAdmin();
    }

    // Service Bookings (independent service appointments)
    match /service_bookings/{bookingId} {
      // Clients can create their own bookings
      allow create: if isAuthenticated() && 
                    request.resource.data.userId == request.auth.uid;
      
      // Allow authenticated read for availability calculation
      // This is needed so clients can see which slots are already booked
      allow read: if isAuthenticated();
      
      // Staff/Admin can update all fields
      // Clients can only update non-critical fields (like cancellation)
      allow update: if isStaffOrAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalPrice', 'serviceId', 'scheduledTime', 'paymentStatus', 'paidAmount'])
      );
      
      // Only admin can delete
      allow delete: if isAdmin();
    }
  }
}
