rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -----------------------------------------------------------------
    // HELPER FUNCTIONS
    // -----------------------------------------------------------------

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Tenant Member Check (Document Lookup)
    function isTenantMember(tenantId) {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tenantId == tenantId;
    }

    // Tenant Admin Check
    function isTenantAdmin(tenantId) {
      let userData = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return isAuthenticated() && 
             userData.tenantId == tenantId && 
             (userData.role == 'admin' || userData.role == 'owner');
    }

    // -----------------------------------------------------------------
    // RULES
    // -----------------------------------------------------------------

    // [Users]
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // [Tenants]
    match /tenants/{tenantId} {
      // Basic Read: Tenant Members
      allow read: if isTenantMember(tenantId);
      allow write: if false; // Created via Cloud Functions

      // [Billing Subscription] - READ ONLY for Client
      match /billing/subscription {
        allow read: if isTenantMember(tenantId);
        allow write: if false; 
      }
      
      // [Billing Events] - Admin Read Only
      match /billing_events/{eventId} {
         allow read: if isTenantAdmin(tenantId);
         allow write: if false;
      }

      // [Domain Data Catch-all] - Strict Isolation
      match /{document=**} {
        allow read, write: if isTenantMember(tenantId);
      }
    }
    
    match /{document=**} {
      allow read, write: if false; 
    }
  }
}
