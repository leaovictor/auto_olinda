rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Fetch user role from the 'users' collection
    function getUserRole() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data != null ? userDoc.data.role : null;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() == 'staff';
    }

    function isStaffOrAdmin() {
      return isAdmin() || isStaff();
    }

    // --- Collection Rules ---

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaffOrAdmin();
      allow write: if isOwner(userId) || isAdmin();

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);
        allow write: if isStaffOrAdmin(); // Staff/Admin send notifications
        allow update: if isOwner(userId); // Client marks as read
      }

      // Vehicles subcollection (user's vehicles)
      match /vehicles/{vehicleId} {
        allow read: if isOwner(userId) || isStaffOrAdmin();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId) || isAdmin();
      }
    }

    // Vehicles collection
    match /vehicles/{vehicleId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isStaffOrAdmin();
      allow update, delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Appointments collection (Active)
    match /appointments/{appointmentId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() || isStaffOrAdmin();
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isStaffOrAdmin();
    }

    // Legacy Bookings
    match /bookings/{bookingId} {
      allow read, write: if isAdmin();
    }

    // Services collection
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Plans collection
    match /plans/{planId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Products collection
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons collection
    match /coupons/{couponId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Subscriptions collection
    match /subscriptions/{subscriptionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isStaffOrAdmin();
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Availability collection
    match /availability/{dateId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Settings collection (Admin settings)
    match /settings/{settingId} {
      allow read: if isStaffOrAdmin();
      allow write: if isAdmin();
    }

    // Config collection (Calendar, etc.)
    match /config/{configId} {
      allow read: if true;
      allow write: if isAdmin();
      
      match /blocked_dates/{dateId} {
        allow read: if isAuthenticated();
        allow write: if isAdmin();
      }
    }

    // Admin Events collection
    match /admin_events/{eventId} {
      allow read, write: if isAdmin();
    }
  }
}
