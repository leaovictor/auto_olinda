rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================================================
    // Helper Functions
    // ==========================================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    // ── Custom claim accessors ──────────────────────────────────────────────
    // These read from server-set custom claims — clients CANNOT fake them.

    function claimTenantId() {
      return request.auth.token.tenantId;
    }

    function claimRole() {
      return request.auth.token.role;
    }

    // ── Tenant isolation ───────────────────────────────────────────────────
    // Core rule: user's tenantId claim MUST match the document path tenantId.
    // This is the primary cross-tenant access prevention mechanism.

    function isSameTenant(tenantId) {
      return isAuthenticated() && claimTenantId() == tenantId;
    }

    function isTenantAdmin(tenantId) {
      return isSameTenant(tenantId) && claimRole() == 'admin';
    }

    function isTenantStaff(tenantId) {
      return isSameTenant(tenantId) && claimRole() in ['admin', 'staff'];
    }

    function isTenantMember(tenantId) {
      return isSameTenant(tenantId) && claimRole() in ['admin', 'staff', 'customer'];
    }

    function isOwner(tenantId, ownerId) {
      return isSameTenant(tenantId) && request.auth.uid == ownerId;
    }

    // ── Incoming data validation helpers ───────────────────────────────────

    // Prevents clients from writing a tenantId field that doesn't match their claim.
    // Call on create operations where the doc has a tenantId field.
    function incomingTenantIdMatchesClaim(tenantId) {
      return request.resource.data.tenantId == tenantId;
    }

    // Fields that are NEVER allowed to be written by clients in updates.
    function noSensitiveFieldsUpdated(forbiddenFields) {
      return !request.resource.data.diff(resource.data)
        .affectedKeys()
        .hasAny(forbiddenFields);
    }

    // ==========================================================================
    // LEGACY (flat) collections — backward compat during migration window
    // Tighten or remove after full tenant migration is verified.
    // ==========================================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId ||
        request.auth.token.role in ['admin', 'staff']
      );
      allow update: if isAuthenticated() && (
        request.auth.uid == userId ||
        request.auth.token.role == 'admin'
      );
      allow create, delete: if isAuthenticated() && request.auth.token.role == 'admin';

      match /notifications/{notifId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow write: if isAuthenticated() && request.auth.token.role in ['admin', 'staff'];
        allow update: if isAuthenticated() && request.auth.uid == userId
          && noSensitiveFieldsUpdated(['title', 'body', 'type', 'timestamp']);
      }

      match /vehicles/{vehicleId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == userId ||
          request.auth.token.role in ['admin', 'staff']
        );
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update: if isAuthenticated() && (
          request.auth.uid == userId || request.auth.token.role == 'admin'
        );
        allow delete: if isAuthenticated() && request.auth.token.role == 'admin';
      }
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.token.role in ['admin', 'staff'];
    }

    match /subscriptions/{subscriptionId} {
      // NO client create — all writes go through Cloud Functions
      allow create: if false;
      allow read: if isAuthenticated() && (
        request.auth.token.role in ['admin', 'staff'] ||
        resource.data.userId == request.auth.uid
      );
      allow update: if isAuthenticated() && request.auth.token.role == 'admin';
      allow delete: if false;
    }

    match /vehicles/{vehicleId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.role in ['admin', 'staff']
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || request.auth.token.role == 'admin'
      );
      allow delete: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.role == 'admin';
    }

    match /config/{configId} {
      allow read: if true;
      allow write: if isAuthenticated() && request.auth.token.role == 'admin';
      match /blocked_dates/{dateId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated() && request.auth.token.role == 'admin';
      }
    }

    match /nda_acceptances/{id} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && (
        request.auth.token.role == 'admin' ||
        resource.data.userId == request.auth.uid
      );
      allow update, delete: if false;
    }

    // ==========================================================================
    // MULTI-TENANT: /tenants/{tenantId}/...
    //
    // Security principles:
    //  1. isSameTenant() is required on EVERY rule — enforces cross-tenant isolation
    //  2. Subscriptions are write-locked for clients (Cloud Functions only)
    //  3. Users can only update their own non-sensitive fields
    //  4. Logs are append-only (no client writes at all)
    //  5. Admin settings are admin-only read/write
    // ==========================================================================

    match /tenants/{tenantId} {
      // Root tenant document: admin reads only.
      // NEVER allow client writes — only Admin SDK (Cloud Functions).
      allow read: if isTenantAdmin(tenantId);
      allow write: if false;

      // ── Users ─────────────────────────────────────────────────────────────
      match /users/{userId} {
        allow read: if isTenantStaff(tenantId) || isOwner(tenantId, userId);

        // Users can update only safe fields (fcmToken, displayName, phone)
        // Admins can update everything
        allow update: if isTenantAdmin(tenantId)
          || (
            isOwner(tenantId, userId) &&
            noSensitiveFieldsUpdated(['role', 'tenantId', 'status', 'strikeUntil', 'noShowCount', 'asaasCustomerId'])
          );

        // User creation goes through Cloud Functions (setUserTenantClaim, createTenant)
        allow create: if false;
        allow delete: if isTenantAdmin(tenantId);

        // ── Notifications ──────────────────────────────────────────────────
        match /notifications/{notifId} {
          allow read: if isOwner(tenantId, userId);
          // Cloud Functions write notifications; user can only mark as read
          allow update: if isOwner(tenantId, userId)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
          allow create, delete: if false;
        }
      }

      // ── Customers (CRM) ────────────────────────────────────────────────────
      match /customers/{customerId} {
        allow read: if isTenantStaff(tenantId);
        allow create, update: if isTenantStaff(tenantId);
        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Bookings ───────────────────────────────────────────────────────────
      match /bookings/{bookingId} {
        allow read: if isTenantStaff(tenantId)
          || (isTenantMember(tenantId) && resource.data.userId == request.auth.uid);

        // Bookings are created ONLY via Cloud Function createBookingV2
        allow create: if false;

        // Staff/admin: full update
        // Customer: only safe, non-structural fields (e.g., rating)
        allow update: if isTenantStaff(tenantId)
          || (
            isTenantMember(tenantId) &&
            resource.data.userId == request.auth.uid &&
            noSensitiveFieldsUpdated(['status', 'totalPrice', 'serviceIds', 'scheduledTime', 'paymentStatus', 'tenantId', 'userId'])
          );

        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Subscriptions ──────────────────────────────────────────────────────
      match /subscriptions/{subscriptionId} {
        allow read: if isTenantStaff(tenantId)
          || (isTenantMember(tenantId) && resource.data.userId == request.auth.uid);

        // ⚠️ ALL subscription writes are done exclusively via Cloud Functions (Admin SDK)
        // Clients MUST NOT be able to write subscriptions directly.
        allow create, update, delete: if false;
      }

      // ── Subscription Status Logs ───────────────────────────────────────────
      match /subscription_status_logs/{logId} {
        allow read: if isTenantStaff(tenantId);
        allow write: if false; // Cloud Functions only
      }

      // ── Tenant Audit Logs ──────────────────────────────────────────────────
      match /logs/{logId} {
        allow read: if isTenantAdmin(tenantId);
        allow write: if false; // tenantLogger service writes via Admin SDK only
      }

      // ── Services ──────────────────────────────────────────────────────────
      match /services/{serviceId} {
        allow read: if isTenantMember(tenantId);
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      // ── Plans ─────────────────────────────────────────────────────────────
      match /plans/{planId} {
        allow read: if isTenantMember(tenantId);
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      // ── Vehicles ──────────────────────────────────────────────────────────
      match /vehicles/{vehicleId} {
        allow read: if isTenantStaff(tenantId)
          || (isTenantMember(tenantId) && resource.data.userId == request.auth.uid);

        // Customer creates their own vehicle; tenantId must match claim
        allow create: if isTenantMember(tenantId)
          && request.resource.data.userId == request.auth.uid
          && incomingTenantIdMatchesClaim(tenantId);

        allow update: if isTenantAdmin(tenantId)
          || (isTenantMember(tenantId) && resource.data.userId == request.auth.uid);

        allow delete: if isTenantAdmin(tenantId);
      }

      // ── Config ────────────────────────────────────────────────────────────
      match /config/{configId} {
        allow read: if isTenantMember(tenantId);
        allow create, update, delete: if isTenantAdmin(tenantId);

        match /blocked_dates/{dateId} {
          allow read: if isTenantMember(tenantId);
          allow create, update, delete: if isTenantAdmin(tenantId);
        }
      }

      // ── Prices (Pricing Matrix) ────────────────────────────────────────────
      match /prices/{priceId} {
        allow read: if isTenantMember(tenantId);
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      // ── Coupons ────────────────────────────────────────────────────────────
      match /coupons/{couponId} {
        allow read: if isTenantMember(tenantId);
        allow create, update, delete: if isTenantAdmin(tenantId);
      }

      // ── Wash Logs ─────────────────────────────────────────────────────────
      match /wash_logs/{logId} {
        allow read: if isTenantStaff(tenantId)
          || (isTenantMember(tenantId) && resource.data.userId == request.auth.uid);
        allow write: if false; // Cloud Functions only
      }

      // ── Aggregated Metrics / Dashboard ────────────────────────────────────
      match /aggregated_metrics/{metricId} {
        allow read: if isTenantStaff(tenantId);
        allow write: if false; // Cloud Functions only
      }

      // ── Leads Clients ─────────────────────────────────────────────────────
      match /leads_clients/{plate} {
        allow read: if isTenantStaff(tenantId);
        allow create, update, delete: if isTenantStaff(tenantId);
        // Customer can claim an unclaimed lead (link their account)
        allow update: if isTenantMember(tenantId)
          && (resource.data.uid == null || resource.data.uid == '')
          && request.resource.data.uid == request.auth.uid
          && noSensitiveFieldsUpdated(['name', 'phone', 'email', 'plate', 'tenantId']);
      }

      // ── Active Services (Quick Entry) ──────────────────────────────────────
      match /servicos_ativos/{serviceId} {
        allow read: if true; // Unauthenticated read for client-facing tracking link
        allow create, update, delete: if isTenantStaff(tenantId);
        allow update: if isTenantMember(tenantId)
          && (resource.data.userId == null || resource.data.userId == '')
          && request.resource.data.userId == request.auth.uid
          && noSensitiveFieldsUpdated(['status', 'price', 'serviceId', 'tenantId', 'staffId']);
      }

      // ── Admin Settings ─────────────────────────────────────────────────────
      match /admin_settings/{settingId} {
        // Admin-only — no customer or staff access
        allow read, write: if isTenantAdmin(tenantId);
      }

      // ── Settings (public tenant config) ────────────────────────────────────
      match /settings/{settingId} {
        allow read: if isTenantMember(tenantId);
        allow write: if isTenantAdmin(tenantId);
      }

      // ── NDA Acceptances ────────────────────────────────────────────────────
      match /nda_acceptances/{id} {
        allow create: if isTenantMember(tenantId)
          && request.resource.data.userId == request.auth.uid
          && incomingTenantIdMatchesClaim(tenantId);
        allow read: if isTenantAdmin(tenantId)
          || (isTenantMember(tenantId) && resource.data.userId == request.auth.uid);
        // Immutable audit document — no updates or deletes ever
        allow update, delete: if false;
      }

    } // end /tenants/{tenantId}

  } // end /databases/{database}/documents
} // end service cloud.firestore
