{
    "name": "functions",
    "scripts": {
        "lint": "npx eslint --ext .js,.ts .",
        "build": "npx tsc",
        "build:watch": "npx tsc --watch",
        "serve": "npm run build && firebase emulators:start --only functions",
        "shell": "npm run build && firebase functions:shell",
        "start": "npm run shell",
        "deploy": "firebase deploy --only functions",
        "logs": "firebase functions:log",
        "dev": "firebase emulators:start --import=./emulator-data --export-on-exit",
        "dev:build": "npm run build && firebase emulators:start --import=./emulator-data --export-on-exit",
        "dev:watch": "npx concurrently \"npm run build:watch\" \"firebase emulators:start --import=./emulator-data --export-on-exit\""
    },
    "engines": {
        "node": ">=20"
    },
    "main": "lib/index.js",
    "dependencies": {
        "firebase-admin": "^13.7.0",
        "firebase-functions": "^7.2.3",
        "stripe": "^20.0.0"
    },
    "devDependencies": {
        "@types/babel__core": "^7.20.5",
        "@typescript-eslint/eslint-plugin": "^5.12.0",
        "@typescript-eslint/parser": "^5.12.0",
        "concurrently": "^9.2.1",
        "eslint": "^8.9.0",
        "eslint-config-google": "^0.14.0",
        "eslint-plugin-import": "^2.25.4",
        "firebase-functions-test": "^3.1.0",
        "typescript": "^6.0.2"
    },
    "private": true
}
